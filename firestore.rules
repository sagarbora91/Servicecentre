rules_version = '2';

// Auth & role rules (M1). Per-collection rules for the remaining entities are
// expanded and emulator-tested in M2. Default-deny is in force for anything not
// matched below.
//
// The client route guards (lib/.../auth_guard.dart) mirror these checks; the
// server rules here are the real enforcement.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function profileExists() {
      return exists(
        /databases/$(database)/documents/users/$(request.auth.uid)
      );
    }
    function profile() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      ).data;
    }
    function role() {
      return profile().role;
    }
    // Active staff with a recognized role. Inactive accounts are denied, which
    // matches the client guard (RoleHomeScreen shows a "deactivated" message).
    function isStaff() {
      return signedIn() && profileExists() && profile().active == true &&
        profile().role in
          ['owner', 'supervisor', 'counter', 'technician', 'store'];
    }
    function canFinance() {
      return isStaff() && profile().role in ['owner', 'supervisor'];
    }

    match /jobs/{id} {
      allow read, write: if isStaff();
    }
    match /invoices/{id} {
      allow read, write: if canFinance();
    }
    match /payments/{id} {
      allow read, write: if canFinance();
    }
    match /parts/{id} {
      allow read: if isStaff();
      allow write: if isStaff() &&
        profile().role in ['owner', 'supervisor', 'store'];
    }
    match /customers/{id} {
      allow read, write: if isStaff();
    }
    match /watches/{id} {
      allow read, write: if isStaff();
    }
    match /stockMovements/{id} {
      // Append-only stock ledger: staff record movements; never edited/deleted.
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if false;
    }
    match /users/{id} {
      // Any signed-in user may read their own profile (so the app can discover
      // its own role/active status); staff may read others. Only the owner may
      // create/modify staff docs and thus assign roles.
      allow read: if (signedIn() && request.auth.uid == id) || isStaff();
      allow write: if isStaff() && profile().role == 'owner';
    }

    // Default deny — anything not explicitly allowed above is blocked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
