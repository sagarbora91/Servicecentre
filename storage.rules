rules_version = '2';

// M6: job photos live under jobs/{jobId}/{intake|delivery}/...; any signed-in
// staff member may read/write them (the app gates access by auth + role).
// NOTE: Storage rules can't cheaply read the users role doc, so role-level
// gating (vs. plain signed-in) is a follow-up via a custom claim. These rules
// are not emulator-tested in CI (the rules job covers Firestore only).
service firebase.storage {
  match /b/{bucket}/o {
    match /jobs/{jobId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // Default deny — anything else is blocked.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
